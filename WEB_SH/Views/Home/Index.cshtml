@{
    ViewData["Title"] = "Accueil";
    Layout = "_Layout";
}

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-custom sticky-top">
    <div class="container">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
            <i class="fas fa-briefcase"></i> PORTOF
        </a>
        <div class="ms-auto d-flex gap-2">
            <a asp-controller="Account" asp-action="Login" class="btn btn-custom-login">
                <i class="fas fa-sign-in-alt"></i> Log In
            </a>
            <a asp-controller="Account" asp-action="ChoixRole" class="btn btn-custom-signup">
                <i class="fas fa-user-plus"></i> Sign Up
            </a>
            <a asp-controller="Account" asp-action="Entreprise" class="btn btn-custom-entreprise">
                <i class="fas fa-sign-in-alt"></i> Entreprise
            </a>
        </div>
    </div>
</nav>

<!-- Hero Section -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 animate-fade-in">
                <h1 class="hero-title">Votre Portfolio, <span style="color: #06b6d4;">Votre Avenir</span></h1>
                <p class="hero-subtitle">Créez votre portfolio professionnel et connectez-vous avec les meilleurs recruteurs du monde.</p>
                <a asp-controller="Account" asp-action="ChoixRole" class="btn btn-hero">
                    Commencer Maintenant <i class="fas fa-arrow-right ms-2"></i>
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="text-white display-5 fw-bold">Pourquoi choisir PORTOF ?</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card text-center">
                    <div class="feature-icon">🎨</div>
                    <h3>Portfolio Personnalisé</h3>
                    <p>Créez un portfolio unique qui reflète votre personnalité</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card text-center">
                    <div class="feature-icon">🤝</div>
                    <h3>Connexion Directe</h3>
                    <p>Les recruteurs peuvent vous contacter directement</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card text-center">
                    <div class="feature-icon">⚡</div>
                    <h3>Gestion Simplifiée</h3>
                    <p>Gérez facilement vos compétences et projets</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Footer -->
<footer class="footer">
    <div class="container">
        <div class="row">
            <div class="col-md-6">
                <h4><i class="fas fa-briefcase"></i> PORTOF</h4>
                <p class="text-white-50">La plateforme qui connecte talents et opportunités.</p>
            </div>
            <div class="col-md-6 text-md-end">
                <h5 class="mb-3">Suivez-nous</h5>
                <a href="#" class="social-icon"><i class="fab fa-facebook-f"></i></a>
                <a href="#" class="social-icon"><i class="fab fa-instagram"></i></a>
                <a href="#" class="social-icon"><i class="fab fa-linkedin-in"></i></a>
                <a href="#" class="social-icon"><i class="fab fa-twitter"></i></a>
            </div>
        </div>
    </div>
</footer>