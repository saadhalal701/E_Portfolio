@using WEB_SH.Entities
@model IEnumerable<Personne>
@{
    ViewData["Title"] = "Liste des candidats";
}

<nav class="navbar navbar-expand-lg navbar-custom sticky-top">
    <div class="container">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
            <i class="fas fa-briefcase"></i> PORTOF
        </a>
        <div class="ms-auto d-flex gap-3">
            <a asp-controller="Message" asp-action="Index" class="btn btn-outline-primary position-relative">
                <i class="fas fa-envelope"></i>
            </a>
            <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger">
                <i class="fas fa-sign-out-alt"></i> Logout
            </a>
        </div>
    </div>
</nav>

<div class="container py-5">
    <div class="text-center mb-5 text-white">
        <h1 class="display-4 fw-bold">Portfolios des Candidats</h1>
    </div>

    <div class="row g-4">
        @foreach (var candidat in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="portfolio-card">
                    @if (!string.IsNullOrEmpty(candidat.Photo))
                    {
                        <img src="@candidat.Photo" class="portfolio-img" alt="Portfolio">
                    }
                    else
                    {
                        <div class="portfolio-img bg-primary d-flex align-items-center justify-content-center">
                            <i class="fas fa-user fa-5x text-white"></i>
                        </div>
                    }
                    <div class="portfolio-body">
                        <h5 class="fw-bold">@candidat.Nom @candidat.Prenom</h5>
                        <p class="text-muted mb-3">@(candidat.Bio ?? "Pas de description")</p>
                        <div class="d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@candidat.Id" class="btn btn-primary flex-fill">
                                <i class="fas fa-eye"></i> Voir Plus
                            </a>
                            <a asp-controller="Message" asp-action="Index" asp-route-destinataireId="@candidat.Id" class="btn btn-success flex-fill">
                                <i class="fas fa-envelope"></i> Contacter
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>