@using WEB_SH.Entities
@model Personne
@{
    ViewData["Title"] = "Inscription";
}

<nav class="navbar navbar-expand-lg navbar-custom sticky-top">
    <div class="container">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
            <i class="fas fa-briefcase"></i> PORTOF
        </a>
    </div>
</nav>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="form-container animate-fade-in">
                <!-- AJOUT DU VALIDATION SUMMARY -->
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="text-center mb-4">
                    <h2>Créer un compte</h2>
                    <p class="text-muted">Rejoignez PORTOF en tant que @ViewBag.Role</p>
                </div>

                <form asp-action="Register" method="post">
                    <!-- AJOUT DU TOKEN ANTI-FORGERY -->
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="Role" />

                    <div class="mb-3">
                        <label asp-for="Nom" class="form-label fw-bold"></label>
                        <input asp-for="Nom" class="form-control form-control-lg" />
                        <span asp-validation-for="Nom" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Prenom" class="form-label fw-bold"></label>
                        <input asp-for="Prenom" class="form-control form-control-lg" />
                        <span asp-validation-for="Prenom" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-bold"></label>
                        <input asp-for="Email" class="form-control form-control-lg" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MotDePasse" class="form-label fw-bold"></label>
                        <input asp-for="MotDePasse" type="password" class="form-control form-control-lg" />
                        <span asp-validation-for="MotDePasse" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Telephone" class="form-label fw-bold"></label>
                        <input asp-for="Telephone" class="form-control form-control-lg" />
                        <span asp-validation-for="Telephone" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Bio" class="form-label fw-bold"></label>
                        <textarea asp-for="Bio" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Bio" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3 fw-bold">
                        <i class="fas fa-user-plus me-2"></i> Créer mon compte
                    </button>
                </form>

                <p class="text-center mt-3 mb-0">
                    Déjà un compte ? <a asp-action="Login" class="text-decoration-none fw-bold">Se connecter</a>
                </p>
            </div>
        </div>
    </div>
</div>

<!-- REMPLACEZ LA SECTION Scripts PAR CE CODE -->
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>