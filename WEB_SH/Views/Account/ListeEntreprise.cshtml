@using WEB_SH.Entities
@model IEnumerable<Entreprise>
@{
    ViewData["Title"] = "Liste des entreprises";
}

<nav class="navbar navbar-expand-lg navbar-custom sticky-top">
    <div class="container">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
            <i class="fas fa-briefcase"></i> PORTOF
        </a>
        <div class="ms-auto d-flex gap-3">
            <a asp-controller="Entreprise" asp-action="ListeEntreprise" class="btn btn-outline-primary">
                <i class="fas fa-building"></i> Entreprises
            </a>
            <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger">
                <i class="fas fa-sign-out-alt"></i> Logout
            </a>
        </div>
    </div>
</nav>

<div class="container py-5">
    <div class="text-center mb-5 text-white">
        <h1 class="display-4 fw-bold">Liste des entreprises (test)</h1>
    </div>

    <div class="row g-4">
        @foreach (var e in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="portfolio-card">
                    <div class="portfolio-img bg-secondary d-flex align-items-center justify-content-center">
                        <i class="fas fa-building fa-3x text-white"></i>
                    </div>
                    <div class="portfolio-body">
                        <h5 class="fw-bold">@e.Nom</h5>
                        <p class="text-muted mb-2">Créée le @e.DateCreation.ToString("d")</p>
                        <div class="d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@e.Id" class="btn btn-primary flex-fill">
                                <i class="fas fa-eye"></i> Voir
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>